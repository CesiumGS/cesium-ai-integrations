# Codegen Server Configuration

# Port for the codegen skills MCP server (default: 3005)
PORT=3005

# Public URL of the server
HOST_URL=http://localhost:3005

# Cesium configuration
CESIUM_TOKEN=

# OpenAi configuration (must be a skills-capable model, e.g. gpt-5.4)
OPENAI_URL=
OPENAI_KEY=
OPENAI_MODEL=gpt-5.4

# Optional: separate endpoint used only by `pnpm run upload-skills`.
# Set this when OPENAI_URL points to a proxy/gateway that doesn't expose /skills
# (e.g. Azure AI Foundry). Defaults to https://api.openai.com/v1 when unset.
OPENAI_SKILLS_URL=

# OpenAI Skill IDs — populate by running: pnpm run upload-skills
SKILL_ID_VIEWER=
SKILL_ID_ENTITIES=
SKILL_ID_CAMERA=
SKILL_ID_ANIMATION=
